{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "assets/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/dokfx"
    ],
    "sitemap": {
      "baseUrl": "https://krykomdev.github.io/Implyzer",
      "priority": 0.5,
      "changefreq": "monthly"
    },
    "globalMetadata": {
      "_appName": "Implyzer",
      "_appTitle": "Implyzer",
      "_gitRepo": "https://github.com/KryKomDev/Implyzer",
      "_appLogoPath": "assets/package-icon.png",
      "_appFaviconPath": "assets/package-icon.png",
      "_enableSearch": true,
      "pdf": false,
      "_appFooter": "<span>Copyright &copy; 2026 KryKom and <a href='https://github.com/KryKomDev/Implyzer/graphs/contributors?all=1'>Contributors</a> · Licensed under the MIT License · Source code on <a href='https://github.com/KryKomDev/Implyzer' target='_blank'>GitHub</a> · Generated by <a href='https://dotnet.github.io/docfx/' target='_blank'>DocFX</a> using the <a href='https://github.com/KryKomDev/Dokfx' target='_blank'>Dokfx template</a></span>"
    }
  }
}